{
    "elements": [
        {
            "type": "Label",
            "caption": "BMW CarData Streaming (MQTT). Dieses Modul benötigt einen übergeordneten 'MQTT Client'. Über das Gateway/Verbindungs-Symbol oben wird dieser automatisch angelegt."
        },
        {
            "type": "ExpansionPanel",
            "caption": "1. Zugangsdaten",
            "expanded": true,
            "items": [
                {
                    "type": "Label",
                    "caption": "Die Client-ID wird im BMW CarData Kundenportal erzeugt. Der Client muss für 'CarData Stream' (Scope cardata:streaming:read) abonniert sein - VOR dem Login."
                },
                {
                    "type": "ValidationTextBox",
                    "name": "ClientID",
                    "caption": "Client-ID",
                    "width": "600px"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "VIN",
                    "caption": "Fahrgestellnummer (VIN)",
                    "width": "300px"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "2. Anmeldung (Device Code Flow)",
            "expanded": true,
            "items": [
                {
                    "type": "Label",
                    "caption": "Schritt 1: 'Login starten' klicken. Link + Code erscheinen. Im Browser mit BMW-ID anmelden. Schritt 2: Danach 'Login abschließen' klicken - der MQTT-Client wird dann automatisch konfiguriert."
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "caption": "1. Login starten",
                            "onClick": "BMWCD_RequestDeviceCode($id);"
                        },
                        {
                            "type": "Button",
                            "caption": "2. Login abschließen",
                            "onClick": "BMWCD_CompleteLogin($id);"
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "3. MQTT-Verbindung",
            "expanded": true,
            "items": [
                {
                    "type": "Label",
                    "caption": "Host, Port, TLS, Username und Passwort (id_token) werden beim Login automatisch in den MQTT-Client geschrieben. Das Topic-Abonnement muss einmalig im MQTT-Client eingetragen werden - die exakten Werte zeigt der Button unten."
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "caption": "Verbindungsdaten anzeigen",
                            "onClick": "BMWCD_ShowConnectionInfo($id);"
                        },
                        {
                            "type": "Button",
                            "caption": "MQTT-Client neu konfigurieren",
                            "onClick": "BMWCD_ConfigureMQTT($id);"
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "4. Token-Erneuerung",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Das id_token (MQTT-Passwort) ist nur 1 Stunde gültig und wird automatisch erneuert. Intervall unter 60 Minuten lassen."
                },
                {
                    "type": "NumberSpinner",
                    "name": "RefreshInterval",
                    "caption": "Erneuerung alle (Minuten)",
                    "minimum": 5,
                    "maximum": 59,
                    "suffix": "min"
                },
                {
                    "type": "Button",
                    "caption": "Token jetzt erneuern",
                    "onClick": "BMWCD_RefreshToken($id);"
                }
            ]
        }
    ],
    "actions": [],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv - Streaming eingerichtet"
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "Client-ID fehlt"
        },
        {
            "code": 202,
            "icon": "inactive",
            "caption": "Nicht angemeldet - bitte Login durchführen"
        },
        {
            "code": 203,
            "icon": "inactive",
            "caption": "Login läuft - bitte im Browser anmelden und Login abschließen"
        },
        {
            "code": 204,
            "icon": "error",
            "caption": "VIN fehlt"
        }
    ]
}
